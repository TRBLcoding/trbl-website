{
	"name": "trbl-website",
	"version": "0.9.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint-fix": "eslint . --fix",
		"gen-types": "npx supabase gen types typescript --project-id \"teiboeelbjhxmsiyzpsn\" --schema public > src/lib/supabase/database.types.ts && echo Types generated: src/lib/supabase/database.types.ts",
		"docker-build": "docker build -t trbl-website .",
		"docker-run": "docker run -p 3000:3000 trbl-website"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/byte-size": "^8.1.2",
		"@types/nodemailer": "^8.0.0",
		"daisyui": "^5.5.19",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"super-sitemap": "^1.0.12",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"svelte-dnd-action": "^0.9.69",
		"svelte-multiselect": "^11.7.1",
		"svelte-select": "^5.8.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.13"
	},
	"dependencies": {
		"@fortawesome/free-brands-svg-icons": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@supabase/supabase-js": "^2.105.4",
		"@zerodevx/svelte-toast": "^0.9.6",
		"byte-size": "^9.0.1",
		"dayjs": "^1.11.20",
		"nodemailer": "^8.0.7",
		"p-limit": "^7.3.0",
		"quill": "^2.0.3",
		"sveaflet": "^0.1.4",
		"svelte-fa": "^4.0.4",
